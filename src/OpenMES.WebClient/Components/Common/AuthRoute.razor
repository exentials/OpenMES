@namespace OpenMES.WebClient.Components.Common
@using OpenMES.Data.Dtos.Resources
@using OpenMES.WebClient.Services

@* AuthRoute.razor - Protected Component Wrapper
    Checks authentication before rendering child content.
    Shows loading state while checking auth.
    Redirects to /login if unauthorized.
    
    Usage:
    <AuthRoute>
        <YourProtectedComponent />
    </AuthRoute>
    
    WEB-004: Phase 1 - Auth Guards
*@

@if (IsLoading)
{
    <LoadingSpinner Message="@UiResources.Auth_CheckingAuthentication" />
}
else if (IsAuthorized)
{
    @ChildContent
}
else
{
    <div style="display: flex; align-items: center; justify-content: center; min-height: 200px;">
        <FluentCard Style="padding: 32px; text-align: center;">
            <FluentIcon Value="@(new Icons.Regular.Size48.LockClosed())" 
                       Style="color: #dc3545; margin-bottom: 16px;" />
            <h3>@UiResources.Auth_AccessDenied</h3>
            <p style="color: #666; margin-top: 16px;">
                @UiResources.Auth_NoPermissionPage
            </p>
        </FluentCard>
    </div>
}

@code {
    [Parameter]
    public RenderFragment? ChildContent { get; set; }

    [Inject]
    public IAuthorizationService? AuthorizationService { get; set; }

    [Inject]
    public NavigationManager? Navigation { get; set; }

    private bool IsLoading { get; set; } = true;
    private bool IsAuthorized { get; set; }

    protected override void OnInitialized()
    {
        if (AuthorizationService != null)
        {
            IsAuthorized = AuthorizationService.IsAuthenticated;
        }

        IsLoading = false;

        if (!IsAuthorized)
        {
            Navigation?.NavigateTo("/login");
        }
    }
}
