@page "/action/{Id:int}"
@using OpenMES.WebClient.Components.Dialogs
@using OpenMES.WebClient.Components.Machine
@using OpenMES.WebClient.Components.Actions
@using OpenMES.Data.Common
@inherits ClientComponentBase<ActionViewModel>
@* ── Header ──────────────────────────────────────────────────────────────── *@
<div style="display:flex;align-items:center;gap:12px;padding:16px 16px 0;">
    <button @onclick="NavigateHome" style="@BackBtnStyle">←</button>
    @if (ViewModel.Machine is not null)
    {
        <div style="flex:1;">
            <div style="font-size:22px;font-weight:500;color:var(--neutral-foreground-rest);">
                @ViewModel.Machine.Code
            </div>
            <div style="font-size:14px;color:var(--neutral-foreground-hint);">
                @ViewModel.Machine.Description
            </div>
        </div>
        <div style="@StatusBadgeStyle">@StatusLabel</div>
    }
</div>

@* ── Context strip ────────────────────────────────────────────────────────── *@
@if (ViewModel.ActivePhase is not null)
{
    <div style="margin:12px 16px 0;padding:12px 16px;
                background:var(--neutral-layer-2);border-radius:10px;
                border:1px solid var(--neutral-stroke-layer-rest);">
        <div style="font-size:12px;color:var(--neutral-foreground-hint);margin-bottom:2px;">
            @UiResources.Action_ActivePhase
        </div>
        <div style="font-size:16px;font-weight:500;color:var(--neutral-foreground-rest);">
            @ViewModel.ActivePhase.PhaseNumber — @ViewModel.ActivePhase.Description
        </div>
        <div style="display:flex;gap:16px;margin-top:6px;font-size:13px;color:var(--neutral-foreground-hint);">
                <span>@UiResources.Action_ConfirmedShort: @ViewModel.ActivePhase.ConfirmedQuantity / @ViewModel.ActivePhase.PlannedQuantity</span>
            @if (ViewModel.ActivePhase.ScrapQuantity > 0)
            {
                <span style="color:var(--error-foreground);">@($"{UiResources.Action_ScrapShort}: {ViewModel.ActivePhase.ScrapQuantity}")</span>
            }
        </div>
    </div>
}

<div style="padding:16px;">

@* ════ SCREEN: MAIN ═════════════════════════════════════════════════════════ *@
@if (ViewModel.Screen == ActionScreen.Main)
{
    @if (IsLoading)
    {
        <FluentProgressRing Style="margin:60px auto;display:block;" />
    }
    else
    {
        <div style="margin-top:8px;padding:12px 14px;background:var(--neutral-layer-2);border:1px solid var(--neutral-stroke-layer-rest);border-radius:10px;">
            <div style="font-size:13px;font-weight:600;color:var(--neutral-foreground-rest);margin-bottom:8px;">@UiResources.Action_GuideTitle</div>
            <div style="display:flex;flex-direction:column;gap:4px;font-size:13px;color:var(--neutral-foreground-hint);">
                <span>@(SelectedOperatorId.HasValue ? $"✓ {UiResources.Action_GuideStepOperatorSelected}" : $"1. {UiResources.Action_GuideStepOperator}")</span>
                <span>@(ViewModel.ActivePhase is not null ? $"✓ {UiResources.Action_GuideStepPhaseSelected}" : $"2. {UiResources.Action_GuideStepPhase}")</span>
                <span>@(ViewModel.HasOpenSession ? $"✓ {UiResources.Action_GuideStepSessionOpen}" : $"3. {UiResources.Action_GuideStepSession}")</span>
            </div>
            @if (ViewModel.ActivePhase is null)
            {
                <button @onclick="OpenPhasePickerAsync" style="margin-top:10px;@MiniActionBtnStyle">@UiResources.Action_GuideSelectPhaseCta</button>
            }
        </div>

        <div style="display:grid;grid-template-columns:1fr 1fr;gap:12px;margin-top:8px;">

            @if (!ViewModel.HasOpenSession)
            {
                <button @onclick="StartWorkAsync" style="@ActionBtnStyle("accent")">
                    <div style="font-size:28px;margin-bottom:6px;">▶</div>
                    <div>@UiResources.Action_StartWork</div>
                </button>
            }
            else
            {
                <button @onclick="CloseSessionAsync" style="@ActionBtnStyle("neutral")">
                    <div style="font-size:28px;margin-bottom:6px;">■</div>
                    <div>@UiResources.Action_CloseSession</div>
                </button>
            }

            <button @onclick="ShowDeclareAsync"
                    disabled="@(!ViewModel.CanDeclare)"
                    style="@ActionBtnStyle(ViewModel.CanDeclare ? "green" : "disabled")">
                <div style="font-size:28px;margin-bottom:6px;">✓</div>
                <div>@UiResources.Action_DeclareQty</div>
            </button>

            <button @onclick="HandleMachineStateAsync" style="@ActionBtnStyle("warn")">
                <div style="font-size:28px;margin-bottom:6px;">⚠</div>
                <div>@MachineStateActionLabel</div>
            </button>

            <button @onclick="ShowShiftScreenAsync" style="@ActionBtnStyle("neutral")">
                <div style="font-size:28px;margin-bottom:6px;">👤</div>
                <div>@ShiftActionLabel</div>
            </button>

        </div>

        <div style="margin-top:16px;padding:12px 14px;background:var(--neutral-layer-2);border:1px solid var(--neutral-stroke-layer-rest);border-radius:10px;">
            <div style="font-size:13px;color:var(--neutral-foreground-hint);margin-bottom:10px;">@UiResources.Action_PlacementsTitle</div>

            @if (ViewModel.OpenPlacements.Count == 0)
            {
                <div style="font-size:13px;color:var(--neutral-foreground-hint);">@UiResources.Action_NoPlacementsForMachine</div>
            }
            else
            {
                @foreach (var placement in ViewModel.OpenPlacements)
                {
                    var isSelected = ViewModel.SelectedPlacementId == placement.Id;
                    var isBusy = IsPlacementBusy(placement);
                    <div style="padding:10px;border-radius:8px;border:1px solid @(isSelected ? "var(--accent-stroke-control-rest)" : "var(--neutral-stroke-layer-rest)");margin-bottom:8px;background:@(isSelected ? "var(--accent-fill-rest)" : "var(--neutral-layer-1)");color:@(isSelected ? "var(--foreground-on-accent-rest)" : "var(--neutral-foreground-rest)");opacity:@(isBusy ? "0.75" : "1");">
                        <div style="display:flex;justify-content:space-between;align-items:center;gap:10px;">
                            <button @onclick="() => OnPlacementSelectedAsync(placement)"
                                    disabled="@isBusy"
                                    style="background:transparent;border:none;color:inherit;cursor:pointer;text-align:left;padding:0;flex:1;">
                                <div style="font-size:14px;font-weight:600;">@placement.PhaseNumber — @placement.PhaseConfirmNumber</div>
                                <div style="font-size:12px;opacity:0.85;">@PlacementStatusLabel(placement.Status)</div>
                            </button>
                            <span style="@PlacementBadgeStyle(placement.Status)">@PlacementStatusLabel(placement.Status)</span>
                        </div>

                        <div style="display:flex;gap:8px;flex-wrap:wrap;margin-top:8px;">
                            @if (placement.Status == MachinePhasePlacementStatus.Placed)
                            {
                                <button @onclick="() => StartSetupForPlacementAsync(placement)" disabled="@isBusy" style="@MiniActionBtnStyle">@UiResources.Action_PlacementSetup</button>
                                <button @onclick="() => StartWorkForPlacementAsync(placement)" disabled="@isBusy" style="@MiniActionBtnStyle">@UiResources.Action_PlacementWork</button>
                            }
                            else if (placement.Status == MachinePhasePlacementStatus.InSetup)
                            {
                                <button @onclick="() => PausePlacementAsync(placement)" disabled="@isBusy" style="@MiniActionBtnStyle">@UiResources.Action_PlacementPauseSetup</button>
                                <button @onclick="() => StartWorkForPlacementAsync(placement)" disabled="@isBusy" style="@MiniActionBtnStyle">@UiResources.Action_PlacementSwitchToWork</button>
                            }
                            else if (placement.Status == MachinePhasePlacementStatus.SetupPaused)
                            {
                                <button @onclick="() => ResumePlacementAsync(placement)" disabled="@isBusy" style="@MiniActionBtnStyle">@UiResources.Action_PlacementResumeSetup</button>
                                <button @onclick="() => StartWorkForPlacementAsync(placement)" disabled="@isBusy" style="@MiniActionBtnStyle">@UiResources.Action_PlacementStartWork</button>
                            }
                            else if (placement.Status == MachinePhasePlacementStatus.InWork)
                            {
                                <button @onclick="() => PausePlacementAsync(placement)" disabled="@isBusy" style="@MiniActionBtnStyle">@UiResources.Action_PlacementPauseWork</button>
                            }
                            else if (placement.Status == MachinePhasePlacementStatus.WorkPaused)
                            {
                                <button @onclick="() => ResumePlacementAsync(placement)" disabled="@isBusy" style="@MiniActionBtnStyle">@UiResources.Action_PlacementResumeWork</button>
                            }

                            <button @onclick="() => AskClosePlacementAsync(placement)" disabled="@isBusy" style="@MiniDangerBtnStyle">@UiResources.Action_PlacementClose</button>
                            @if (isBusy)
                            {
                                <span style="font-size:12px;color:var(--neutral-foreground-hint);align-self:center;">...</span>
                            }
                        </div>
                    </div>
                }
            }
        </div>

        @if (ViewModel.OpenSession is not null)
        {
            <div style="margin-top:16px;padding:12px 16px;
                        background:var(--success-background);border-radius:10px;
                        border:1px solid var(--success-border);
                        display:flex;align-items:center;gap:12px;">
                <FluentIcon Value="@(new Icons.Regular.Size20.Timer())"
                            Style="color:var(--success-foreground);" />
                <div>
                    <div style="font-size:14px;font-weight:500;color:var(--success-foreground);">
                        @UiResources.Action_SessionOpen — @ViewModel.OpenSession.SessionType
                    </div>
                    <div style="font-size:12px;color:var(--success-foreground);opacity:0.8;">
                        @ViewModel.OpenSession.OperatorName · @UiResources.Action_Started @ViewModel.OpenSession.StartTime.ToLocalTime().ToString("HH:mm")
                    </div>
                </div>
            </div>
        }

        @if (IsClosePlacementDialogOpen && PlacementPendingClose is not null)
        {
            <div style="position: fixed; inset: 0; background: rgba(0,0,0,0.4); z-index: 1100; display:flex; align-items:center; justify-content:center;">
                <div style="width:min(520px,92vw); background:var(--neutral-layer-1); border:1px solid var(--neutral-stroke-layer-rest); border-radius:12px; padding:16px;">
                    <div style="font-size:18px;font-weight:600;color:var(--neutral-foreground-rest);margin-bottom:10px;">
                        @UiResources.Action_CloseSession
                    </div>
                    <div style="font-size:14px;color:var(--neutral-foreground-rest);margin-bottom:16px;">
                        @UiResources.Action_PlacementCloseConfirm
                    </div>
                    <div style="display:flex;justify-content:flex-end;gap:8px;">
                        <button @onclick="CancelClosePlacementAsync" style="@MiniActionBtnStyle">@UiResources.Action_Cancel</button>
                        <button @onclick="ConfirmClosePlacementAsync" style="@MiniDangerBtnStyle">@UiResources.Action_Confirm</button>
                    </div>
                </div>
            </div>
        }
    }
}

@if (ViewModel.Screen == ActionScreen.Declare)
{
    <div style="max-width:360px;margin:0 auto;">

        <div style="text-align:center;margin-bottom:20px;">
            <div style="font-size:18px;font-weight:500;color:var(--neutral-foreground-rest);">
                @UiResources.Action_DeclareQty
            </div>
            <div style="font-size:13px;color:var(--neutral-foreground-hint);margin-top:4px;">
                @ViewModel.ActivePhase?.PhaseNumber — @ViewModel.ActivePhase?.Description
            </div>
        </div>

        <div style="text-align:center;margin-bottom:8px;">
            <div style="font-size:13px;color:var(--neutral-foreground-hint);">@UiResources.Action_GoodPieces</div>
            <div style="font-size:48px;font-weight:500;color:var(--neutral-foreground-rest);
                        line-height:1.1;letter-spacing:-1px;">
                @ViewModel.ConfirmedQty.ToString("0.###")
            </div>
        </div>

        <NumericPad @bind-Value="ViewModel.ConfirmedQty" Label="@UiResources.Action_GoodPieces" />

        <div style="display:flex;align-items:center;gap:12px;margin:20px 0 8px;">
            <div style="flex:1;height:1px;background:var(--neutral-stroke-layer-rest);"></div>
            <span style="font-size:13px;color:var(--neutral-foreground-hint);">@UiResources.Action_ScrapOptional</span>
            <div style="flex:1,height:1px;background:var(--neutral-stroke-layer-rest);"></div>
        </div>

        <div style="text-align:center;margin-bottom:8px;">
            <div style="font-size:36px;font-weight:500;color:var(--error-foreground);line-height:1.1;">
                @ViewModel.ScrapQty.ToString("0.###")
            </div>
        </div>

        <NumericPad @bind-Value="ViewModel.ScrapQty" Label="@UiResources.Action_ScrapOptional" />

        <div style="display:grid;grid-template-columns:1fr 1fr;gap:12px;margin-top:24px;">
            <button @onclick="GoBack" style="@ActionBtnStyle("neutral")">
                <div>← @UiResources.Action_Cancel</div>
            </button>
            <button @onclick="ConfirmDeclareAsync"
                    disabled="@(ViewModel.ConfirmedQty <= 0)"
                    style="@ActionBtnStyle(ViewModel.ConfirmedQty > 0 ? "green" : "disabled")">
                <div>✓ @UiResources.Action_Confirm</div>
            </button>
        </div>

    </div>
}

@if (ViewModel.Screen == ActionScreen.SessionTypePicker)
{
    <div style="max-width:360px;margin:0 auto;">

        <div style="text-align:center;margin-bottom:24px;">
            <div style="font-size:18px;font-weight:500;color:var(--neutral-foreground-rest);">
                @UiResources.Action_ChooseSessionType
            </div>
        </div>

        <div style="display:grid;grid-template-columns:1fr 1fr;gap:12px;">
            <button @onclick="@(() => StartSessionOfType(WorkSessionType.Work))"
                    style="@ActionBtnStyle("accent")">
                <div style="font-size:28px;margin-bottom:6px;">▶</div>
                <div>@UiResources.Action_SessionWork</div>
            </button>
            <button @onclick="@(() => StartSessionOfType(WorkSessionType.Setup))"
                    style="@ActionBtnStyle("warn")">
                <div style="font-size:28px;margin-bottom:6px;">⚙</div>
                <div>@UiResources.Action_SessionSetup</div>
            </button>
        </div>

        <div style="margin-top:16px;">
            <button @onclick="GoBack" style="@ActionBtnStyle("neutral")">
                <div>← @UiResources.Action_Cancel</div>
            </button>
        </div>

    </div>
}

@if (ViewModel.Screen == ActionScreen.PhasePicker)
{
    <PhasePickerScreen Phases="@AvailablePhases"
                       OnPhaseSelected="@OnPhaseSelectedAsync"
                       OnCancel="@GoBack" />
}

@if (ViewModel.Screen == ActionScreen.CheckIn)
{
    <OperatorShiftScreen CurrentShift="@ViewModel.OperatorShift"
                         OnShiftChanged="@OnShiftChangedAsync"
                         OnCancel="@GoBack" />
}

<OperatorSelectionDialog IsOpen="@IsOperatorDialogOpen"
                         Operators="@AvailableOperators"
                         OnCancel="@CloseOperatorDialog"
                         OnConfirm="@OnOperatorSelectedAsync" />

<StopReasonDialog IsOpen="@IsStopReasonDialogOpen"
                  Reasons="@AvailableStopReasons"
                  OnCancel="@CloseStopReasonDialog"
                  OnConfirm="@OnStopReasonSelectedAsync" />

</div>

@code {
    private string MachineStateActionLabel => ViewModel.Status switch
    {
        MachineStatus.Running => UiResources.Action_MachineStop,
        MachineStatus.Setup   => UiResources.Action_Resume,
        MachineStatus.Stopped => UiResources.Action_Start,
        _                     => UiResources.Action_Start,
    };

    private string ShiftActionLabel => ViewModel.IsOperatorPresent
        ? UiResources.Action_CheckOut
        : UiResources.Action_CheckIn;

    private string PlacementStatusLabel(MachinePhasePlacementStatus status) => status switch
    {
        MachinePhasePlacementStatus.Placed => UiResources.Action_PlacementStatusPlaced,
        MachinePhasePlacementStatus.InSetup => UiResources.Action_PlacementStatusInSetup,
        MachinePhasePlacementStatus.SetupPaused => UiResources.Action_PlacementStatusSetupPaused,
        MachinePhasePlacementStatus.InWork => UiResources.Action_PlacementStatusInWork,
        MachinePhasePlacementStatus.WorkPaused => UiResources.Action_PlacementStatusWorkPaused,
        MachinePhasePlacementStatus.Closed => UiResources.Action_PlacementStatusClosed,
        _ => status.ToString()
    };

    private string StatusLabel => ViewModel.Status switch
    {
        MachineStatus.Running     => UiResources.Machine_Running,
        MachineStatus.Setup       => UiResources.Machine_Setup,
        MachineStatus.Idle        => UiResources.Machine_Idle,
        MachineStatus.Stopped     => UiResources.Machine_Stopped,
        MachineStatus.Fault       => UiResources.Machine_Fault,
        MachineStatus.Maintenance => UiResources.Machine_Maintenance,
        MachineStatus.Blocked     => UiResources.Machine_Blocked,
        MachineStatus.Starved     => UiResources.Machine_Starved,
        _                         => UiResources.Machine_Manual
    };

    private string StatusColor => ViewModel.Status switch
    {
        MachineStatus.Running     => "var(--success-foreground)",
        MachineStatus.Setup       => "var(--warning-foreground)",
        MachineStatus.Fault       => "var(--error-foreground)",
        MachineStatus.Stopped     => "var(--error-foreground)",
        MachineStatus.Maintenance => "#7F77DD",
        _                         => "var(--neutral-foreground-hint)"
    };

    private string StatusBg => ViewModel.Status switch
    {
        MachineStatus.Running     => "var(--success-background)",
        MachineStatus.Setup       => "var(--warning-background)",
        MachineStatus.Fault       => "var(--error-background)",
        MachineStatus.Stopped     => "var(--error-background)",
        MachineStatus.Maintenance => "#EEEDFE",
        _                         => "var(--neutral-layer-2)"
    };

    private string StatusBadgeStyle =>
        "font-size:14px;font-weight:500;padding:6px 16px;border-radius:99px;" +
        $"background:{StatusBg};color:{StatusColor};white-space:nowrap;";

    private static string BackBtnStyle =>
        "height:44px;width:44px;border-radius:10px;border:1px solid var(--neutral-stroke-layer-rest);" +
        "background:var(--neutral-layer-2);color:var(--neutral-foreground-rest);" +
        "font-size:20px;cursor:pointer;flex-shrink:0;";

    private static string ActionBtnStyle(string variant) =>
        "display:flex;flex-direction:column;align-items:center;justify-content:center;" +
        "height:110px;border-radius:14px;cursor:pointer;" +
        "font-size:16px;font-weight:500;border:1px solid transparent;" +
        "transition:opacity 0.15s;" +
        variant switch
        {
            "accent"   => "background:var(--accent-fill-rest);color:var(--foreground-on-accent-rest);border-color:var(--accent-stroke-control-rest);",
            "green"    => "background:var(--success-background);color:var(--success-foreground);border-color:var(--success-border);",
            "warn"     => "background:var(--warning-background);color:var(--warning-foreground);border-color:var(--warning-border);",
            "disabled" => "background:var(--neutral-layer-2);color:var(--neutral-foreground-hint);opacity:0.5;cursor:not-allowed;",
            _          => "background:var(--neutral-layer-2);color:var(--neutral-foreground-rest);border-color:var(--neutral-stroke-layer-rest);"
        };

    private static string MiniActionBtnStyle =>
        "padding:6px 10px;border-radius:8px;border:1px solid var(--neutral-stroke-layer-rest);" +
        "background:var(--neutral-layer-2);color:var(--neutral-foreground-rest);font-size:12px;cursor:pointer;";

    private static string MiniDangerBtnStyle =>
        "padding:6px 10px;border-radius:8px;border:1px solid var(--error-border);" +
        "background:var(--error-background);color:var(--error-foreground);font-size:12px;cursor:pointer;";

    private static string PlacementBadgeStyle(MachinePhasePlacementStatus status) =>
        "font-size:11px;font-weight:600;padding:4px 8px;border-radius:999px;border:1px solid transparent;" +
        status switch
        {
            MachinePhasePlacementStatus.Placed => "background:var(--neutral-layer-2);color:var(--neutral-foreground-rest);border-color:var(--neutral-stroke-layer-rest);",
            MachinePhasePlacementStatus.InSetup => "background:var(--warning-background);color:var(--warning-foreground);border-color:var(--warning-border);",
            MachinePhasePlacementStatus.SetupPaused => "background:var(--neutral-layer-2);color:var(--warning-foreground);border-color:var(--warning-border);",
            MachinePhasePlacementStatus.InWork => "background:var(--success-background);color:var,--success-foreground);border-color:var(--success-border);",
            MachinePhasePlacementStatus.WorkPaused => "background:var(--neutral-layer-2);color:var(--success-foreground);border-color:var(--success-border);",
            _ => "background:var(--neutral-layer-2);color:var(--neutral-foreground-hint);border-color:var(--neutral-stroke-layer-rest);"
        };
}
