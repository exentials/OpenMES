@page "/phasepickinglist"
@attribute [Authorize]
@inherits BasePage<PhasePickingListDto, int, Edit>
@rendermode InteractiveServer

<FluentToolbar>
    <FluentButton Appearance="Appearance.Accent"
                  IconStart="@(new Icons.Regular.Size20.Add())"
                  OnClick="@AddInDialog">@UiResources.Button_Add</FluentButton>
</FluentToolbar>

<FluentDataGrid TGridItem="PhasePickingListDto" ItemsProvider="@ItemsProvider"
                GenerateHeader="GenerateHeaderOption.Sticky"
                DisplayMode="DataGridDisplayMode.Table">
    <PropertyColumnExt Property="@(p => p.PhaseNumber)" Sortable="true" />
    <PropertyColumnExt Property="@(p => p.PartNumber)" Sortable="true" />
    <PropertyColumnExt Property="@(p => p.PartDescription)" Sortable="true" />
    <PropertyColumnExt Property="@(p => p.UnitOfMeasure)" Sortable="true" />
    <PropertyColumnExt Property="@(p => p.RequiredQuantity)" Sortable="true" />
    <PropertyColumnExt Property="@(p => p.PickedQuantity)" Sortable="true" />
    <PropertyColumnExt Property="@(p => p.StorageLocationCode)" Sortable="true" />
    <PropertyColumnExt Property="@(p => p.Status)" Sortable="true" />
    <TemplateColumn Title="@UiResources.Label_Auto">
        @if (context.IsAutomatic)
        {
            <FluentIcon Value="@(new Icons.Regular.Size16.CheckboxChecked())" />
        }
        else
        {
            <FluentIcon Value="@(new Icons.Regular.Size16.CheckboxUnchecked())" />
        }
    </TemplateColumn>
    <TemplateColumn Title="@UiResources.Label_Consumable">
        @if (context.IsConsumable)
        {
            <FluentBadge Appearance="Appearance.Neutral">@UiResources.Label_Consumable</FluentBadge>
        }
    </TemplateColumn>
    <TemplateColumn Title="@UiResources.Label_Phantom">
        @if (context.IsPhantom)
        {
            <FluentBadge Appearance="Appearance.Neutral">@UiResources.Label_Phantom</FluentBadge>
        }
    </TemplateColumn>
    <TemplateColumn Title="@UiResources.Label_Actions">
        <FluentButton Appearance="Appearance.Stealth" IconStart="@(new Icons.Regular.Size16.Edit())" OnClick="@(() => EditInDialog(context))" />
        <FluentButton Appearance="Appearance.Stealth" IconStart="@(new Icons.Regular.Size16.Delete())" OnClick="@(() => DeleteItem(context))" />
        <FluentButton Appearance="Appearance.Stealth" IconStart="@(new Icons.Regular.Size16.Glasses())" OnClick="@(() => ShowItem(context))" />
    </TemplateColumn>
</FluentDataGrid>

<FluentPaginator State="@pagination" />
