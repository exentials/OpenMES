@inherits BaseEdit<ProductionOrderDto>

<FluentDialogHeader ShowDismiss="false">
    <FluentStack VerticalAlignment="VerticalAlignment.Center">
        <FluentIcon Value="@(new Icons.Regular.Size24.ClipboardTask())" />
        <FluentLabel Typo="Typography.PaneHeader">@Dialog.Instance.Parameters.Title</FluentLabel>
    </FluentStack>
</FluentDialogHeader>

<FluentDialogBody>
    <FluentStack Orientation="Orientation.Vertical" VerticalGap="8">
        <FluentNumberField Label="Plant Id" @bind-Value="@Content.PlantId" Required="true" />
        <FluentNumberField Label="Material Id" @bind-Value="@Content.MaterialId" Required="true" />
        <FluentTextField Label="Order Number" @bind-Value="@Content.OrderNumber" Required="true" MaxLength="20" />
        <FluentTextField Label="Order Type" @bind-Value="@Content.OrderType" MaxLength="20" />
        <FluentNumberField Label="Planned Quantity" @bind-Value="@Content.PlannedQuantity" Required="true" Min="0" />
    </FluentStack>
</FluentDialogBody>

<FluentDialogFooter>
    <FluentButton Appearance="Appearance.Accent" IconStart="@(new Icons.Regular.Size20.Save())" OnClick="@SaveAsync">@UiResources.Button_Save</FluentButton>
    <FluentButton Appearance="Appearance.Neutral" OnClick="@CancelAsync">@UiResources.Button_Cancel</FluentButton>
</FluentDialogFooter>
<FluentDialogHeader ShowDismiss="false">
    <FluentStack VerticalAlignment="VerticalAlignment.Center">
        <FluentIcon Value="@(new Icons.Regular.Size24.ClipboardCheckmark())" />
        <FluentLabel Typo="Typography.PaneHeader">@Dialog.Instance.Parameters.Title</FluentLabel>
    </FluentStack>
</FluentDialogHeader>

<FluentDialogBody>
    <FluentStack Orientation="Orientation.Vertical" VerticalGap="8">
    <FluentTextField Label="@DtoResources.ProductionOrder_OrderNumber" @bind-Value="@Content.OrderNumber" Required="true" />
    <FluentNumberField Label="@DtoResources.ProductionOrder_PlantId" @bind-Value="@Content.PlantId" Required="true" />
    <FluentNumberField Label="@DtoResources.ProductionOrder_MaterialId" @bind-Value="@Content.MaterialId" />
    <FluentTextField Label="@DtoResources.ProductionOrder_OrderType" @bind-Value="@Content.OrderType" />
    <FluentNumberField Label="@DtoResources.ProductionOrder_PlannedQuantity" @bind-Value="@Content.PlannedQuantity" Min="0" />
    </FluentStack>
</FluentDialogBody>

<FluentDialogFooter>
    <FluentButton Appearance="Appearance.Accent" IconStart="@(new Icons.Regular.Size20.Save())" OnClick="@SaveAsync">@UiResources.Button_Save</FluentButton>
    <FluentButton Appearance="Appearance.Neutral" OnClick="@CancelAsync">@UiResources.Button_Cancel</FluentButton>
</FluentDialogFooter>
