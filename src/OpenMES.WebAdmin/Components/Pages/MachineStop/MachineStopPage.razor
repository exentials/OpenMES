@page "/machinestop"
@attribute [Authorize]
@inherits BasePage<MachineStopDto, int, Edit>
@rendermode InteractiveServer

<FluentToolbar>
    <FluentButton Appearance="Appearance.Accent"
                  IconStart="@(new Icons.Regular.Size20.Add())"
                  OnClick="@AddInDialog">@UiResources.Button_Add</FluentButton>
</FluentToolbar>

<FluentDataGrid TGridItem="MachineStopDto" ItemsProvider="@ItemsProvider"
                GenerateHeader="GenerateHeaderOption.Sticky"
                DisplayMode="DataGridDisplayMode.Table">
    <PropertyColumnExt Property="@(p => p.MachineCode)" Sortable="true" />
    <PropertyColumnExt Property="@(p => p.MachineStopReasonCode)" Sortable="true" />
    <PropertyColumnExt Property="@(p => p.MachineStopReasonCategory)" Sortable="true" />
    <PropertyColumnExt Property="@(p => p.MachineStopReasonDescription)" Sortable="true" />
    <PropertyColumnExt Property="@(p => p.StartDate)" Sortable="true" Format="g" />
    <PropertyColumnExt Property="@(p => p.EndDate)" Sortable="true" Format="g" />
    <TemplateColumn Title="@UiResources.Label_Open">
        @if (context.EndDate is null)
        {
            <FluentBadge Appearance="Appearance.Accent">@UiResources.Label_Open</FluentBadge>
        }
    </TemplateColumn>
    <TemplateColumn Title="@UiResources.Label_Actions">
        <FluentButton Appearance="Appearance.Stealth" IconStart="@(new Icons.Regular.Size16.Edit())" OnClick="@(() => EditInDialog(context))" />
        <FluentButton Appearance="Appearance.Stealth" IconStart="@(new Icons.Regular.Size16.Delete())" OnClick="@(() => DeleteItem(context))" />
    </TemplateColumn>
</FluentDataGrid>

<FluentPaginator State="@pagination" />
