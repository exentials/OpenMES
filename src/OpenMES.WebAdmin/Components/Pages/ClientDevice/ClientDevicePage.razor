@page "/clientdevice"
@attribute [Authorize]
@inherits BasePage<ClientDeviceDto, int, Edit>
@rendermode InteractiveServer

<FluentToolbar>
    <FluentButton Appearance="Appearance.Accent"
                  IconStart="@(new Icons.Regular.Size20.Add())"
                  OnClick="@AddInDialog">@UiResources.Button_Add</FluentButton>
</FluentToolbar>

<FluentDataGrid TGridItem="ClientDeviceDto" ItemsProvider="@ItemsProvider"
                GenerateHeader="GenerateHeaderOption.Sticky"
                DisplayMode="DataGridDisplayMode.Table">
    <PropertyColumnExt Property="@(p => p.Name)" Sortable="true" />
    <PropertyColumnExt Property="@(p => p.Description)" Sortable="true" />
    <TemplateColumn Title="@DtoResources.ClientDevice_Enabled">
        @if (context.Enabled)
        {
            <FluentIcon Value="@(new Icons.Regular.Size16.CheckboxChecked())" />
        }
        else
        {
            <FluentIcon Value="@(new Icons.Regular.Size16.CheckboxUnchecked())" />
        }
    </TemplateColumn>
    <TemplateColumn Title="@UiResources.Label_Actions">
        <FluentButton Appearance="Appearance.Stealth" IconStart="@(new Icons.Regular.Size16.Edit())" OnClick="@(() => EditInDialog(context))" />
        <FluentButton Appearance="Appearance.Stealth" IconStart="@(new Icons.Regular.Size16.Delete())" OnClick="@(() => DeleteItem(context))" />
    </TemplateColumn>
</FluentDataGrid>

<FluentPaginator State="@pagination" />
